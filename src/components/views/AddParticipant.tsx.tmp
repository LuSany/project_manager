'use client';

import { useState } from 'react';
import { Button } from '@/components/ui/button';
import { Input } from '@/components/ui/input';
import { Label } from '@/components/ui/label';
import {
  Dialog,
  DialogContent,
  DialogDescription,
  DialogFooter,
  DialogHeader,
  DialogTitle,
} from '@/components/ui/dialog';
import {
  Select,
  SelectContent,
  SelectItem,
  SelectTrigger,
  SelectValue,
} from '@/components/ui/select';

interface AddParticipantProps {
  reviewId: string;
  onSuccess?: () => void;
}

export function AddParticipant({ reviewId, onSuccess }: AddParticipantProps) {
  const [open, setOpen] = useState(false);
  const [userId, setUserId] = useState('');
  const [role, setRole] = useState<'REVIEWER' | 'OBSERVER' | 'SECRETARY'>('REVIEWER');
  const [loading, setLoading] = useState(false);

  const [users, setUsers] = useState<Array<{ id: string; name: string; email: string }>>([]);

  // 获取用户列表
  useState(() => {
    fetch('/api/v1/users')
      .then((res) => res.json())
      .then((data) => {
        if (data.success) {
          setUsers(data.data || []);
        }
      });
  }, []);

  const handleSubmit = async (e: React.FormEvent) => {
    e.preventDefault();
    if (!userId) return;

    setLoading(true);

    try {
      const response = await fetch(`/api/v1/reviews/${reviewId}/participants`, {
        method: 'POST',
        headers: { 'Content-Type': 'application/json' },
        body: JSON.stringify({
          userId,
          role,
        }),
      });

      const data = await response.json();
      if (data.success) {
        setOpen(false);
        setUserId('');
        setRole('REVIEWER');
        onSuccess?.();
      }
    } catch (err) {
      console.error('添加参与者失败:', err);
    } finally {
      setLoading(false);
    }
  };

  return (
    <Dialog open={open} onOpenChange={setOpen}>
      <DialogTrigger asChild>
        <Button>添加参与者</Button>
      </DialogTrigger>
      <DialogContent className="sm:max-w-[600px]">
        <DialogHeader>
          <DialogTitle>添加评审参与者</DialogTitle>
          <DialogDescription>选择用户并指定角色</DialogDescription>
        </DialogHeader>
        <form onSubmit={handleSubmit} className="space-y-4">
          <div className="space-y-2">
            <div>
              <Label htmlFor="user">用户</Label>
              <Select value={userId} onValueChange={setUserId} required>
                <SelectTrigger>
                  {users.find((u) => u.id === userId)?.name || '选择用户'}
                </SelectTrigger>
                <SelectContent>
                  {users.map((user) => (
                    <SelectItem key={user.id} value={user.id}>
                      {user.name} ({user.email})
                    </SelectItem>
                  ))}
                </SelectContent>
              </Select>
            </div>
            <div>
              <Label htmlFor="role">角色</Label>
              <Select value={role} onValueChange={setRole}>
                <SelectTrigger>
                  {role === 'REVIEWER' && '评审人'}
                  {role === 'OBSERVER' && '观察者'}
                  {role === 'SECRETARY' && '记录员'}
                </SelectTrigger>
                <SelectContent>
                  <SelectItem value="REVIEWER">评审人</SelectItem>
                  <SelectItem value="OBSERVER">观察者</SelectItem>
                  <SelectItem value="SECRETARY">记录员</SelectItem>
                </SelectContent>
              </Select>
            </div>
          </div>
          <DialogFooter>
            <Button type="button" variant="outline" onClick={() => setOpen(false)}>
              取消
            </Button>
            <Button type="submit" disabled={loading || !userId}>
              {loading ? '添加中...' : '添加'}
            </Button>
          </DialogFooter>
        </form>
      </DialogContent>
    </Dialog>
  );
}
