// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ============================================================================
// 用户与权限
// ============================================================================

model User {
  id           String     @id @default(cuid())
  email        String     @unique
  passwordHash String
  name         String
  avatar       String?
  phone        String?
  department   String? // 部门
  position     String? // 职位
  status       UserStatus @default(PENDING)
  role         SystemRole @default(EMPLOYEE)
  createdAt    DateTime   @default(now())
  updatedAt    DateTime   @updatedAt

  // 关系
  ownedProjects           Project[]                @relation("ProjectOwner")
  projectMembers          ProjectMember[]
  passwordResetTokens     PasswordResetToken[]
  taskAssignees           TaskAssignee[]           @relation("TaskAssignees")
  taskWatchers            TaskWatcher[]            @relation("TaskWatchers")
  reviewedRequirements    Requirement[]            @relation("RequirementReviewer")
  authoredProposals       Proposal[]               @relation("ProposalAuthor")
  authoredAcceptances     RequirementAcceptance[]  @relation("AcceptanceAuthor")
  reviewParticipants      ReviewParticipant[]
  ownedRisks              Risk[]                   @relation("RiskOwner")
  uploadedFiles           FileStorage[]
  notifications           Notification[]
  notificationPreferences NotificationPreference[]
  notificationIgnores     NotificationIgnore[]
  acceptedTasks           Task[]                   @relation("TaskAcceptor")
  requirementDiscussions  RequirementDiscussion[]

  @@index([email])
  @@map("users")
}

enum UserStatus {
  PENDING // 待审批
  ACTIVE // 已激活
  DISABLED // 已禁用
}

enum SystemRole {
  ADMIN // 系统管理员
  PROJECT_ADMIN // 项目管理员
  PROJECT_OWNER // 项目所有者
  PROJECT_MEMBER // 项目成员
  EMPLOYEE // 普通员工
}

// ============================================================================
// 项目管理
// ============================================================================

model Project {
  id          String        @id @default(cuid())
  name        String
  description String?
  status      ProjectStatus @default(PLANNING)
  startDate   DateTime?
  endDate     DateTime?
  ownerId     String
  createdAt   DateTime      @default(now())
  updatedAt   DateTime      @updatedAt

  // 关系
  owner               User                 @relation("ProjectOwner", fields: [ownerId], references: [id], onDelete: Cascade)
  members             ProjectMember[]
  milestones          Milestone[]
  tasks               Task[]
  requirements        Requirement[]
  issues              Issue[]
  reviews             Review[]
  risks               Risk[]
  notificationIgnores NotificationIgnore[] @relation("notificationIgnores")

  @@index([ownerId])
  @@index([status])
  @@map("projects")
}

enum ProjectStatus {
  PLANNING // 计划中
  ACTIVE // 进行中
  ON_HOLD // 暂停
  COMPLETED // 已完成
  CANCELLED // 已取消
}

model ProjectMember {
  projectId String
  userId    String
  role      ProjectMemberRole
  joinedAt  DateTime          @default(now())

  // 关系
  project Project @relation(fields: [projectId], references: [id], onDelete: Cascade)
  user    User    @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@id([projectId, userId])
  @@map("project_members")
}

enum ProjectMemberRole {
  PROJECT_OWNER // 项目所有者 - 完整权限
  PROJECT_ADMIN // 项目管理员 - 可管理成员和设置
  PROJECT_MEMBER // 项目成员 - 可参与任务
}

// ============================================================================
// 里程碑管理
// ============================================================================

model Milestone {
  id          String          @id @default(cuid())
  title       String
  description String?
  status      MilestoneStatus @default(NOT_STARTED)
  progress    Int             @default(0) // 0-100
  dueDate     DateTime?
  projectId   String
  createdAt   DateTime        @default(now())
  updatedAt   DateTime        @updatedAt

  // 关系
  project Project @relation(fields: [projectId], references: [id], onDelete: Cascade)
  tasks   Task[]  @relation("TaskMilestone")

  @@index([projectId])
  @@index([status])
  @@map("milestones")
}

enum MilestoneStatus {
  NOT_STARTED // 未开始
  IN_PROGRESS // 进行中
  COMPLETED // 已完成
  CANCELLED // 已取消
}

// ============================================================================
// 密码重置Token
// ============================================================================

model PasswordResetToken {
  id        String   @id @default(cuid())
  token     String   @unique
  userId    String
  expiresAt DateTime
  used      Boolean  @default(false)
  createdAt DateTime @default(now())

  // 关系
  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([token])
  @@map("password_reset_tokens")
}

// ============================================================================
// 任务管理 (第一阶段基础表)
// ============================================================================

model Task {
  id             String       @id @default(cuid())
  title          String
  description    String?
  status         TaskStatus   @default(TODO)
  progress       Int          @default(0) // 0-100
  priority       TaskPriority @default(MEDIUM)
  startDate      DateTime?
  dueDate        DateTime?
  estimatedHours Float?
  projectId      String
  milestoneId    String?
  issueId        String?
  acceptorId     String? // 验收人 ID
  createdAt      DateTime     @default(now())
  updatedAt      DateTime     @updatedAt

  // 关系
  project      Project                 @relation(fields: [projectId], references: [id], onDelete: Cascade)
  milestone    Milestone?              @relation("TaskMilestone", fields: [milestoneId], references: [id], onDelete: SetNull)
  issue        Issue?                  @relation("TaskIssue", fields: [issueId], references: [id], onDelete: SetNull)
  assignees    TaskAssignee[]
  watchers     TaskWatcher[]           @relation("TaskWatcher")
  subTasks     SubTask[]
  taskTags     TaskTag[]
  riskTasks    RiskTask[]              @relation("RiskTaskRelation")
  acceptor     User?                   @relation("TaskAcceptor", fields: [acceptorId], references: [id], onDelete: SetNull)
  discussions  RequirementDiscussion[] @relation("TaskDiscussion")
  // 任务依赖关系
  dependencies TaskDependency[]        @relation("TaskDependents") // 当前任务依赖的其他任务
  dependents   TaskDependency[]        @relation("TaskDependencies") // 依赖当前任务的其他任务

  @@index([projectId])
  @@index([milestoneId])
  @@index([issueId])
  @@index([status])
  @@index([priority])
  @@index([acceptorId])
  @@map("tasks")
}

enum TaskStatus {
  TODO // 未开始
  IN_PROGRESS // 进行中
  REVIEW // 待评审
  TESTING // 测试中
  DONE // 已完成
  CANCELLED // 已取消
  DELAYED // 延期
  BLOCKED // 阻塞
}

enum TaskPriority {
  LOW // 低
  MEDIUM // 中
  HIGH // 高
  CRITICAL // 紧急/关键
}

// 任务执行人关联表
model TaskAssignee {
  taskId     String
  userId     String
  assignedAt DateTime @default(now())

  // 关系
  task Task @relation(fields: [taskId], references: [id], onDelete: Cascade)
  user User @relation("TaskAssignees", fields: [userId], references: [id], onDelete: Cascade)

  @@id([taskId, userId])
  @@map("task_assignees")
}

// 任务关注者关联表
model TaskWatcher {
  taskId    String
  userId    String
  createdAt DateTime @default(now())

  // 关系
  task Task @relation("TaskWatcher", fields: [taskId], references: [id], onDelete: Cascade)
  user User @relation("TaskWatchers", fields: [userId], references: [id], onDelete: Cascade)

  @@id([taskId, userId])
  @@index([taskId])
  @@index([userId])
  @@map("task_watchers")
}

// ============================================================================
// 任务依赖管理
// ============================================================================

model TaskDependency {
  id             String         @id @default(cuid())
  taskId         String
  dependsOnId    String
  dependencyType DependencyType @default(FINISH_TO_START)
  createdAt      DateTime       @default(now())

  // 关系
  task      Task @relation("TaskDependents", fields: [taskId], references: [id], onDelete: Cascade)
  dependsOn Task @relation("TaskDependencies", fields: [dependsOnId], references: [id], onDelete: Cascade)

  @@unique([taskId, dependsOnId])
  @@index([taskId])
  @@index([dependsOnId])
  @@map("task_dependencies")
}

enum DependencyType {
  FINISH_TO_START // 前置任务完成后才能开始当前任务
  START_TO_START // 前置任务开始后才能开始当前任务
  FINISH_TO_FINISH // 前置任务完成后才能完成当前任务
  START_TO_FINISH // 前置任务开始后才能完成当前任务
}

// ============================================================================
// 子任务管理
// ============================================================================

model SubTask {
  id          String   @id @default(cuid())
  title       String
  description String?
  completed   Boolean  @default(false)
  taskId      String
  parentId    String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  // 关系
  task     Task      @relation(fields: [taskId], references: [id], onDelete: Cascade)
  parent   SubTask?  @relation("SubTaskHierarchy", fields: [parentId], references: [id], onDelete: Cascade)
  children SubTask[] @relation("SubTaskHierarchy")

  @@index([taskId])
  @@index([parentId])
  @@index([completed])
  @@map("subtasks")
}

// ============================================================================
// 标签管理
// ============================================================================

model Tag {
  id        String   @id @default(cuid())
  name      String   @unique
  color     String   @default("#3B82F6")
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  // 关系
  taskTags TaskTag[]

  @@index([name])
  @@map("tags")
}

// 任务与标签关联表
model TaskTag {
  taskId    String
  tagId     String
  createdAt DateTime @default(now())

  // 关系
  task Task @relation(fields: [taskId], references: [id], onDelete: Cascade)
  tag  Tag  @relation(fields: [tagId], references: [id], onDelete: Cascade)

  @@id([taskId, tagId])
  @@index([tagId])
  @@map("task_tags")
}

// ============================================================================
// 任务模板管理
// ============================================================================

model TaskTemplate {
  id           String   @id @default(cuid())
  title        String
  description  String?
  templateData String // JSON格式存储模板配置
  isPublic     Boolean  @default(false)
  createdBy    String?
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  @@index([createdBy])
  @@index([isPublic])
  @@map("task_templates")
}

// ============================================================================
// 需求管理
// ============================================================================

model Requirement {
  id           String              @id @default(cuid())
  title        String
  description  String?
  status       RequirementStatus   @default(PENDING)
  priority     RequirementPriority @default(MEDIUM)
  projectId    String
  reviewedBy   String?
  reviewedAt   DateTime?
  rejectReason String?
  createdAt    DateTime            @default(now())
  updatedAt    DateTime            @updatedAt

  // 关系
  project     Project                 @relation(fields: [projectId], references: [id], onDelete: Cascade)
  reviewer    User?                   @relation("RequirementReviewer", fields: [reviewedBy], references: [id])
  proposals   Proposal[]
  impacts     RequirementImpact[]
  acceptances RequirementAcceptance[]
  issues      Issue[]
  discussions RequirementDiscussion[]
  history     RequirementHistory[]

  @@index([projectId])
  @@index([status])
  @@index([priority])
  @@index([reviewedBy])
  @@map("requirements")
}

enum RequirementStatus {
  PENDING // 待审批
  APPROVED // 已批准
  REJECTED // 已拒绝
  IN_PROGRESS // 进行中
  COMPLETED // 已完成
}

enum RequirementPriority {
  LOW // 低
  MEDIUM // 中
  HIGH // 高
}

// ============================================================================
// 方案评估
// ============================================================================

model Proposal {
  id             String         @id @default(cuid())
  requirementId  String
  userId         String
  content        String
  estimatedHours Float?
  estimatedCost  Float?
  status         ProposalStatus @default(PENDING)
  createdAt      DateTime       @default(now())
  updatedAt      DateTime       @updatedAt

  // 关系
  requirement Requirement @relation(fields: [requirementId], references: [id], onDelete: Cascade)
  user        User        @relation("ProposalAuthor", fields: [userId], references: [id])

  @@index([requirementId])
  @@index([userId])
  @@index([status])
  @@map("proposals")
}

enum ProposalStatus {
  PENDING // 待审核
  ACCEPTED // 已接受
  REJECTED // 已拒绝
}

// ============================================================================
// 波及影响分析
// ============================================================================

model RequirementImpact {
  id            String         @id @default(cuid())
  requirementId String
  description   String
  severity      ImpactSeverity @default(MEDIUM)
  createdAt     DateTime       @default(now())

  // 关系
  requirement Requirement @relation(fields: [requirementId], references: [id], onDelete: Cascade)

  @@index([requirementId])
  @@index([severity])
  @@map("requirement_impacts")
}

enum ImpactSeverity {
  LOW // 低
  MEDIUM // 中
  HIGH // 高
}

// ============================================================================
// 需求验收
// ============================================================================

model RequirementAcceptance {
  id            String           @id @default(cuid())
  requirementId String
  userId        String
  result        AcceptanceResult @default(PENDING)
  notes         String?
  createdAt     DateTime         @default(now())

  // 关系
  requirement Requirement @relation(fields: [requirementId], references: [id], onDelete: Cascade)
  user        User        @relation("AcceptanceAuthor", fields: [userId], references: [id])

  @@index([requirementId])
  @@index([userId])
  @@index([result])
  @@map("requirement_acceptances")
}

enum AcceptanceResult {
  PENDING // 待验收
  PASSED // 通过
  FAILED // 未通过
  CONDITIONAL // 有条件通过
}

// ============================================================================
// 需求讨论
// ============================================================================

model RequirementDiscussion {
  id            String   @id @default(cuid())
  requirementId String
  userId        String
  content       String
  taskId        String?
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  // 关系
  requirement Requirement @relation(fields: [requirementId], references: [id], onDelete: Cascade)
  user        User        @relation(fields: [userId], references: [id], onDelete: Cascade)
  task        Task?       @relation("TaskDiscussion", fields: [taskId], references: [id], onDelete: SetNull)

  @@index([requirementId])
  @@index([userId])
  @@map("requirement_discussions")
}

// ============================================================================
// 需求变更历史
// ============================================================================

model RequirementHistory {
  id            String   @id @default(cuid())
  requirementId String
  changeType    String // STATUS_CHANGE, CONTENT_UPDATE, PRIORITY_CHANGE
  oldValue      String?
  newValue      String?
  changedBy     String
  changeReason  String?
  createdAt     DateTime @default(now())

  // 关系
  requirement Requirement @relation(fields: [requirementId], references: [id], onDelete: Cascade)

  @@index([requirementId])
  @@index([changeType])
  @@map("requirement_history")
}

// ============================================================================
// 问题管理
// ============================================================================

model Issue {
  id            String        @id @default(cuid())
  title         String
  description   String?
  status        IssueStatus   @default(OPEN)
  priority      IssuePriority @default(MEDIUM)
  projectId     String
  requirementId String? // 关联的需求 ID
  autoClose     Boolean       @default(true)
  resolvedAt    DateTime?
  createdAt     DateTime      @default(now())
  updatedAt     DateTime      @updatedAt

  // 关系
  project     Project      @relation(fields: [projectId], references: [id], onDelete: Cascade)
  requirement Requirement? @relation(fields: [requirementId], references: [id], onDelete: SetNull)
  tasks       Task[]       @relation("TaskIssue")

  @@index([projectId])
  @@index([status])
  @@index([priority])
  @@index([requirementId])
  @@map("issues")
}

enum IssueStatus {
  OPEN // 待处理
  IN_PROGRESS // 进行中
  RESOLVED // 已解决
  CLOSED // 已关闭
  REOPENED // 重新打开
}

enum IssuePriority {
  LOW // 低
  MEDIUM // 中
  HIGH // 高
  URGENT // 紧急
}

// ============================================================================
// 评审管理
// ============================================================================

model ReviewTypeConfig {
  id          String   @id @default(cuid())
  name        String   @unique
  displayName String
  description String?
  isSystem    Boolean  @default(false)
  isActive    Boolean  @default(true)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  // 关系
  reviews   Review[]
  templates ReviewTemplate[]
}

// ============================================================================
// 评审模板
// ============================================================================

model ReviewTemplate {
  id          String   @id @default(cuid())
  typeId      String
  name        String
  description String?
  isActive    Boolean  @default(true)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  // 关系
  type  ReviewTypeConfig     @relation(fields: [typeId], references: [id], onDelete: Cascade)
  items ReviewTemplateItem[]

  @@index([typeId])
  @@index([isActive])
  @@map("review_templates")
}

model ReviewTemplateItem {
  id         String   @id @default(cuid())
  templateId String
  title      String
  content    String?
  order      Int      @default(0)
  required   Boolean  @default(false)
  createdAt  DateTime @default(now())

  // 关系
  template ReviewTemplate @relation(fields: [templateId], references: [id], onDelete: Cascade)

  @@index([templateId])
  @@map("review_template_items")
}

model Review {
  id             String       @id @default(cuid())
  title          String
  description    String?
  projectId      String
  typeId         String
  scheduledAt    DateTime?
  status         ReviewStatus @default(PENDING)
  passedCriteria Int          @default(0)
  totalScore     Float?
  createdAt      DateTime     @default(now())
  updatedAt      DateTime     @updatedAt

  // 关系
  project      Project             @relation(fields: [projectId], references: [id], onDelete: Cascade)
  type         ReviewTypeConfig    @relation(fields: [typeId], references: [id], onDelete: Restrict)
  materials    ReviewMaterial[]
  participants ReviewParticipant[]
  items        ReviewItem[]
  criteria     ReviewCriterion[]

  @@index([projectId])
  @@index([typeId])
  @@index([status])
  @@map("reviews")
}

enum ReviewStatus {
  PENDING // 待评审
  IN_PROGRESS // 评审中
  COMPLETED // 已完成
  CANCELLED // 已取消
}

model ReviewMaterial {
  id         String   @id @default(cuid())
  reviewId   String
  fileId     String
  fileName   String
  fileType   String
  fileSize   Int
  uploadedAt DateTime @default(now())

  // 关系
  review Review @relation(fields: [reviewId], references: [id], onDelete: Cascade)

  @@index([reviewId])
  @@map("review_materials")
}

model ReviewParticipant {
  reviewId String
  userId   String
  role     ReviewParticipantRole
  joinedAt DateTime              @default(now())

  // 关系
  review Review @relation(fields: [reviewId], references: [id], onDelete: Cascade)
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@id([reviewId, userId])
  @@map("review_participants")
}

enum ReviewParticipantRole {
  REVIEWER // 评审人
  OBSERVER // 观察者
  SECRETARY // 记录员
}

model ReviewItem {
  id          String   @id @default(cuid())
  reviewId    String
  title       String
  description String?
  category    String?
  isRequired  Boolean  @default(false)
  order       Int      @default(0)
  createdAt   DateTime @default(now())

  // 关系
  review Review @relation(fields: [reviewId], references: [id], onDelete: Cascade)

  @@index([reviewId])
  @@map("review_items")
}

model ReviewCriterion {
  id          String   @id @default(cuid())
  reviewId    String
  title       String
  description String?
  weight      Float    @default(1.0)
  maxScore    Float    @default(10)
  order       Int      @default(0)
  createdAt   DateTime @default(now())

  // 关系
  review Review @relation(fields: [reviewId], references: [id], onDelete: Cascade)

  @@index([reviewId])
  @@map("review_criteria")
}

// ============================================================================
// 文件存储
// ============================================================================

model FileStorage {
  id           String   @id @default(cuid())
  fileName     String
  originalName String
  filePath     String
  fileSize     Int
  mimeType     String
  uploadedBy   String
  createdAt    DateTime @default(now())

  // 关系
  uploader User @relation(fields: [uploadedBy], references: [id], onDelete: Restrict)

  @@index([uploadedBy])
  @@index([createdAt])
  @@map("file_storage")
}

// ============================================================================
// 预览服务配置
// ============================================================================

model PreviewServiceConfig {
  id          String             @id @default(cuid())
  serviceType PreviewServiceType
  endpoint    String
  isEnabled   Boolean            @default(true)
  config      String // JSON格式存储服务配置
  createdAt   DateTime           @default(now())
  updatedAt   DateTime           @updatedAt

  @@map("preview_service_configs")
}

enum PreviewServiceType {
  ONLYOFFICE // OnlyOffice
  KKFILEVIEW // KKFileView
  NATIVE // 原生预览
}

// ============================================================================
// 通知系统
// ============================================================================

model Notification {
  id        String           @id @default(cuid())
  type      NotificationType
  title     String
  content   String
  link      String?
  isRead    Boolean          @default(false)
  userId    String
  projectId String?
  createdAt DateTime         @default(now())

  // 关系
  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([isRead])
  @@index([createdAt])
  @@map("notifications")
}

enum NotificationType {
  RISK_ALERT // 风险预警
  REVIEW_INVITE // 评审邀请
  URGENT_TASK // 紧急任务
  TASK_DUE_REMINDER // 任务到期提醒
  TASK_ASSIGNED // 任务分配
  COMMENT_MENTION // 评论提及
  DAILY_DIGEST // 每日摘要
}

model NotificationPreference {
  userId    String
  type      NotificationType
  enabled   Boolean             @default(true)
  channel   NotificationChannel @default(IN_APP)
  createdAt DateTime            @default(now())

  // 关系
  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@id([userId, type, channel])
  @@map("notification_preferences")
}

enum NotificationChannel {
  IN_APP // 站内通知
  EMAIL // 邮件通知
  SMS // 短信通知
}

model NotificationIgnore {
  userId    String
  projectId String
  createdAt DateTime @default(now())

  // 关系
  user    User    @relation(fields: [userId], references: [id], onDelete: Cascade)
  project Project @relation("notificationIgnores", fields: [projectId], references: [id], onDelete: Cascade)

  @@id([userId, projectId])
  @@map("notification_ignores")
}

// ========== 邮件服务模块 ==========

enum EmailStatus {
  PENDING // 待发送
  SENT // 已发送
  DELIVERED // 已送达
  FAILED // 发送失败
  BOUNCED // 退信
}

model EmailConfig {
  id           String   @id @default(cuid())
  name         String   @unique
  provider     String // COMPANY, SMTP, SENDGRID
  apiKey       String?
  smtpHost     String?
  smtpPort     Int?
  smtpUser     String?
  smtpPassword String?
  fromAddress  String
  fromName     String?
  isActive     Boolean  @default(true)
  isDefault    Boolean  @default(false)
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  @@map("email_configs")
}

model EmailLog {
  id           String      @id @default(cuid())
  userId       String?
  projectId    String?
  to           String
  subject      String
  content      String
  templateType String?
  status       EmailStatus @default(PENDING)
  errorMessage String?
  externalId   String?
  sentAt       DateTime?
  createdAt    DateTime    @default(now())

  @@map("email_logs")
}

// 邮件模板 (P1)
model EmailTemplate {
  id        String   @id @default(cuid())
  name      String   @unique
  type      String // TASK_ASSIGNED, TASK_DUE, REVIEW_INVITE, RISK_ALERT, PASSWORD_RESET
  subject   String
  body      String // HTML模板，支持变量替换
  variables String? // JSON格式变量定义
  isActive  Boolean  @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@map("email_templates")
}

// ========== AI服务模块 ==========

enum AIProvider {
  OPENAI
  ANTHROPIC
  CUSTOM
}

enum AIStatus {
  PENDING
  SUCCESS
  FAILED
}

enum AIServiceType {
  RISK_ANALYSIS
  REVIEW_AUDIT
  DOC_PARSE
}

model AIConfig {
  id        String     @id @default(cuid())
  name      String     @unique
  provider  AIProvider @default(OPENAI)
  apiKey    String?
  baseUrl   String?
  model     String     @default("gpt-4o-mini")
  isActive  Boolean    @default(true)
  isDefault Boolean    @default(false)
  config    String? // JSON格式额外配置
  createdAt DateTime   @default(now())
  updatedAt DateTime   @updatedAt

  @@map("ai_configs")
}

model AILog {
  id           String        @id @default(cuid())
  serviceType  AIServiceType
  provider     String
  model        String
  prompt       String
  response     String?
  status       AIStatus      @default(PENDING)
  errorMessage String?
  duration     Int? // 毫秒
  userId       String?
  projectId    String?
  externalId   String? // AI服务返回的ID
  createdAt    DateTime      @default(now())

  @@index([serviceType, createdAt])
  @@map("ai_logs")
}

// ============================================================================
// 审计日志
// ============================================================================

model AuditLog {
  id          String      @id @default(cuid())
  userId      String
  action      AuditAction
  entityType  String
  entityId    String?
  description String?
  ipAddress   String?
  userAgent   String?
  createdAt   DateTime    @default(now())

  @@index([userId])
  @@index([entityType, entityId])
  @@index([action])
  @@index([createdAt])
  @@map("audit_logs")
}

enum AuditAction {
  CREATE
  UPDATE
  DELETE
  VIEW
  LOGIN
  LOGOUT
  LOGIN_FAILED
  EXPORT
  IMPORT
  PERMISSION_CHANGE
  ROLE_CHANGE
  PASSWORD_CHANGE
  SETTINGS_CHANGE
  BULK_DELETE
}

// ============================================================================
// AI响应缓存
// ============================================================================

model AiResponseCache {
  id          String        @id @default(cuid())
  cacheKey    String        @unique
  serviceType AIServiceType
  requestHash String
  response    String
  hitCount    Int           @default(0)
  expiresAt   DateTime
  createdAt   DateTime      @default(now())
  updatedAt   DateTime      @updatedAt

  @@index([serviceType, requestHash])
  @@index([expiresAt])
  @@map("ai_response_cache")
}

// ============================================================================
// Webhook
// ============================================================================

model Webhook {
  id        String   @id @default(cuid())
  name      String
  url       String
  events    String // JSON array of event types
  secret    String?
  isActive  Boolean  @default(true)
  createdBy String
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  deliveries WebhookDelivery[]

  @@index([isActive])
  @@index([createdBy])
  @@map("webhooks")
}

model WebhookDelivery {
  id           String                @id @default(cuid())
  webhookId    String
  event        String
  payload      String // JSON
  status       WebhookDeliveryStatus @default(PENDING)
  statusCode   Int?
  response     String?
  errorMessage String?
  attemptedAt  DateTime              @default(now())
  deliveredAt  DateTime?

  webhook Webhook @relation(fields: [webhookId], references: [id], onDelete: Cascade)

  @@index([webhookId])
  @@index([status])
  @@index([attemptedAt])
  @@map("webhook_deliveries")
}

enum WebhookDeliveryStatus {
  PENDING
  SUCCESS
  FAILED
  TIMEOUT
}

// ============================================================================
// 定时任务
// ============================================================================

model ScheduledJob {
  id          String     @id @default(cuid())
  name        String     @unique
  description String?
  cron        String
  endpoint    String // API endpoint to call
  method      String     @default("POST")
  payload     String? // JSON payload
  isActive    Boolean    @default(true)
  lastRunAt   DateTime?
  lastStatus  JobStatus?
  lastError   String?
  createdBy   String
  createdAt   DateTime   @default(now())
  updatedAt   DateTime   @updatedAt

  @@index([isActive])
  @@index([lastRunAt])
  @@map("scheduled_jobs")
}

enum JobStatus {
  SUCCESS
  FAILED
  TIMEOUT
}

// ============================================================================
// 风险管理
// ============================================================================

model Risk {
  id             String       @id @default(cuid())
  projectId      String
  title          String
  description    String?
  category       RiskCategory @default(TECHNICAL)
  probability    Int          @default(1) // 1-5
  impact         Int          @default(1) // 1-5
  riskLevel      RiskLevel    @default(LOW)
  status         RiskStatus   @default(IDENTIFIED)
  progress       Int          @default(0)
  mitigation     String?
  contingency    String?
  ownerId        String
  isAiIdentified Boolean      @default(false)
  aiRiskScore    Float?
  aiSuggestion   String?
  identifiedDate DateTime     @default(now())
  dueDate        DateTime?
  resolvedDate   DateTime?
  createdAt      DateTime     @default(now())
  updatedAt      DateTime     @updatedAt

  project   Project    @relation(fields: [projectId], references: [id], onDelete: Cascade)
  owner     User       @relation("RiskOwner", fields: [ownerId], references: [id])
  riskTasks RiskTask[]

  @@index([projectId])
  @@index([status])
  @@index([riskLevel])
  @@map("risks")
}

model RiskTask {
  id           String   @id @default(cuid())
  riskId       String
  taskId       String
  relationType String   @default("RELATED") // RELATED, CAUSES, MITIGATES
  createdAt    DateTime @default(now())

  risk Risk @relation(fields: [riskId], references: [id], onDelete: Cascade)
  task Task @relation("RiskTaskRelation", fields: [taskId], references: [id], onDelete: Cascade)

  @@index([riskId])
  @@index([taskId])
  @@map("risk_tasks")
}

enum RiskCategory {
  TECHNICAL // 技术风险
  SCHEDULE // 进度风险
  RESOURCE // 资源风险
  BUDGET // 预算风险
  EXTERNAL // 外部风险
  MANAGEMENT // 管理风险
}

enum RiskLevel {
  LOW // 低
  MEDIUM // 中
  HIGH // 高
  CRITICAL // 关键
}

enum RiskStatus {
  IDENTIFIED // 已识别
  ANALYZING // 分析中
  MITIGATING // 缓解中
  MONITORING // 监控中
  RESOLVED // 已解决
  CLOSED // 已关闭
}

// ============================================================================
// AI 评审分析
// ============================================================================

model ReviewAiAnalysis {
  id           String   @id @default(cuid())
  reviewId     String
  analysisType String // MATERIAL_ANALYSIS, CRITERIA_GENERATION, RISK_IDENTIFICATION, SUMMARY
  result       String // JSON 格式存储分析结果
  aiConfigId   String?
  duration     Int? // 毫秒
  createdAt    DateTime @default(now())

  @@index([reviewId, analysisType])
  @@map("review_ai_analysis")
}
