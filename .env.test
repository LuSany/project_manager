# 测试环境变量配置

# 数据库配置
DATABASE_URL="file:./test.db"
NODE_ENV="test"
TEST_MODE="true"

# AI 服务配置
# MOCK_AI=true 用于跳过真实的 AI 调用，适用于单元测试
MOCK_AI=false

# 日志配置
LOG_LEVEL="error"

# JWT 配置
JWT_SECRET="test-jwt-secret-key-2026"
JWT_EXPIRES_IN="1h"

# 应用配置
NEXT_PUBLIC_APP_URL="http://localhost:3000"

# 仅用于测试 - 不要在生产环境使用
SAFE_MODE_FOR_TESTING="true"
