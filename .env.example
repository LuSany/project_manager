# URL Signing Secret (用于URL签名，至少32字符)
URL_SIGN_SECRET="your-url-signing-secret-change-in-production-minimum-32-characters"

# App Configuration
NEXT_PUBLIC_APP_URL="http://localhost:3000"
NEXT_PUBLIC_APP_NAME="项目管理系统"

